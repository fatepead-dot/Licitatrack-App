      <div id="fbody${fi}" style="display:${open?'block':'none'}">`;
    fase.tasks.forEach((task,ti)=>{
      const k=fi+'_'+ti,isDone=!!planoState[k];
      html+=`<div class="chk-item ${isDone?'done':''}" onclick="toggleTask(${fi},${ti})">
