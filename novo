    const fpct=fase.tasks.length?Math.round(fd/fase.tasks.length*100):0;
    const open=S.get('fopen_'+fi,fi===0);
    html+=`<div style="margin-bottom:14px">
      <div class="phase-hdr" style="--pc:${fase.cor}" onclick="toggleFase(${fi})">
