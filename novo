<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LicitaTrack</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Outfit:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#040d18;--bg2:#071526;--bg3:#0c1e38;--surf:#0e2540;--surf2:#132d4a;
  --border:#1b3d66;--border2:#275280;
  --cyan:#00d4ff;--green:#00e676;--yellow:#ffd740;--orange:#ff9100;
  --red:#ff5252;--purple:#c084fc;--teal:#2dd4bf;
  --txt:#dff0fb;--txt2:#7ab0d0;--txt3:#3d6e8c;
  --r:12px;--r2:8px;
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;overflow:hidden}
body{background:var(--bg);color:var(--txt);font-family:'Outfit',sans-serif;display:flex;flex-direction:column}
body::before{content:'';position:fixed;top:-300px;left:-200px;width:700px;height:700px;
  background:radial-gradient(circle,rgba(0,212,255,.05) 0%,transparent 65%);pointer-events:none;z-index:0}

/* HEADER */
header{flex-shrink:0;z-index:50;background:rgba(4,13,24,.96);backdrop-filter:blur(20px);
  border-bottom:1px solid var(--border);padding:0 20px;height:52px;
  display:flex;align-items:center;justify-content:space-between}
.logo{font-family:'Syne',sans-serif;font-weight:800;font-size:17px;color:var(--cyan);
  display:flex;align-items:center;gap:8px}
.logo em{color:var(--green);font-style:normal}
.logo-tag{background:var(--cyan);color:var(--bg);font-size:8px;font-weight:700;padding:2px 6px;border-radius:4px;letter-spacing:1px}
.hstats{display:flex;gap:16px}
.hstat{text-align:center}
.hstat-v{font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--cyan)}
.hstat-l{font-size:8px;color:var(--txt3);letter-spacing:1px;text-transform:uppercase}
@media(max-width:600px){.hstats{display:none}}

/* NAV */
nav{flex-shrink:0;z-index:40;background:var(--bg2);border-bottom:1px solid var(--border);
  display:flex;gap:2px;padding:7px 14px;overflow-x:auto}
nav::-webkit-scrollbar{display:none}
.tab{padding:6px 13px;border-radius:var(--r2);font-size:12px;font-weight:500;cursor:pointer;
  white-space:nowrap;border:1px solid transparent;transition:all .18s;color:var(--txt2)}
.tab:hover{background:var(--surf);color:var(--txt)}
.tab.active{background:var(--cyan);color:var(--bg);font-weight:600}

/* MAIN */
main{flex:1;overflow-y:auto;padding:18px;position:relative;z-index:1}
main::-webkit-scrollbar{width:5px}
main::-webkit-scrollbar-track{background:var(--bg2)}
main::-webkit-scrollbar-thumb{background:var(--border2);border-radius:3px}
.sec{display:none}.sec.active{display:block}

/* TYPOGRAPHY */
.stitle{font-family:'Syne',sans-serif;font-weight:800;font-size:19px;margin-bottom:4px}
.ssub{font-size:12px;color:var(--txt2);margin-bottom:16px;line-height:1.6}

/* CARD */
.card{background:var(--surf);border:1px solid var(--border);border-radius:var(--r);padding:16px;margin-bottom:14px}

/* GRIDS */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px}
@media(max-width:640px){.g2{grid-template-columns:1fr}}

/* PROGRESS */
.prog-wrap{background:var(--bg3);border-radius:20px;height:7px;overflow:hidden;margin:6px 0}
.prog-bar{height:100%;border-radius:20px;transition:width .5s;background:linear-gradient(90deg,var(--cyan),var(--green))}

/* CHECKLIST */
.chk-item{display:flex;align-items:flex-start;gap:10px;padding:10px 12px;
  border-radius:var(--r2);border:1px solid var(--border);margin-bottom:6px;
  transition:all .18s;cursor:pointer;background:var(--surf)}
.chk-item:hover{border-color:var(--border2);background:var(--surf2)}
.chk-item.done{opacity:.5}
.chk-item.done .chk-lbl{text-decoration:line-through;color:var(--txt3)}
.chk-box{width:20px;height:20px;min-width:20px;border-radius:5px;border:2px solid var(--border2);
  display:flex;align-items:center;justify-content:center;font-size:11px;margin-top:1px;transition:all .18s}
.chk-item.done .chk-box{background:var(--green);border-color:var(--green);color:var(--bg);font-weight:700}
.chk-lbl{font-size:13px;font-weight:500;line-height:1.4}
.chk-sub{font-size:10px;color:var(--txt2);margin-top:2px;line-height:1.4}

/* PHASE */
.phase-hdr{display:flex;align-items:center;gap:10px;padding:10px 14px;border-radius:var(--r);
  margin-bottom:8px;border-left:3px solid var(--pc,var(--cyan));background:var(--surf);
  cursor:pointer;user-select:none;transition:background .18s}
.phase-hdr:hover{background:var(--surf2)}
.phase-dot{width:9px;height:9px;border-radius:50%;background:var(--pc,var(--cyan));flex-shrink:0}
.phase-title{font-family:'Syne',sans-serif;font-weight:700;font-size:13px;flex:1}
.phase-cnt{font-size:10px;color:var(--txt2);font-family:'JetBrains Mono',monospace}

/* FORM */
.fg{display:flex;flex-direction:column;gap:4px}
.fg label{font-size:10px;color:var(--txt2);letter-spacing:.5px;text-transform:uppercase}
.fg input,.fg select{background:var(--surf2);border:1px solid var(--border);border-radius:var(--r2);
  color:var(--txt);padding:8px 11px;font-size:13px;font-family:'Outfit',sans-serif;outline:none;transition:border-color .18s}
.fg input:focus,.fg select:focus{border-color:var(--cyan)}
.fg select option{background:var(--bg2)}
.frow{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:10px}
.frow .fg{flex:1;min-width:130px}

/* BUTTONS */
.btn{padding:8px 16px;border-radius:var(--r2);font-size:12px;font-weight:600;cursor:pointer;
  border:none;transition:all .18s;font-family:'Outfit',sans-serif}
.btn-c{background:var(--cyan);color:var(--bg)}.btn-c:hover{opacity:.85}
.btn-g{background:var(--green);color:var(--bg)}.btn-g:hover{opacity:.85}
.btn-ghost{background:transparent;border:1px solid var(--border2);color:var(--txt2)}
.btn-ghost:hover{border-color:var(--cyan);color:var(--cyan)}
.btn-sm{padding:4px 9px;font-size:10px}
.btn-red{background:var(--red);color:#fff}

/* CALC */
.calc-row{display:flex;justify-content:space-between;align-items:center;
  padding:7px 0;border-bottom:1px solid var(--border)}
.calc-row:last-child{border:none}
.calc-lbl{font-size:12px;color:var(--txt2)}
.calc-val{font-family:'JetBrains Mono',monospace;font-size:13px}
.calc-big{font-size:20px!important;color:var(--green)!important;font-weight:700!important}
.viab{padding:11px;border-radius:var(--r2);text-align:center;font-weight:700;font-size:13px;margin-top:10px}

/* PORTAL CARD */
.pcrd{background:var(--surf);border:1px solid var(--border);border-radius:var(--r);
  padding:14px;transition:all .2s;position:relative;overflow:hidden}
.pcrd::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:var(--pc,var(--cyan));opacity:0;transition:opacity .2s}
.pcrd:hover{border-color:var(--border2);transform:translateY(-2px)}.pcrd:hover::before{opacity:1}
.pcrd-name{font-family:'Syne',sans-serif;font-weight:700;font-size:13px;margin-bottom:3px}
.pcrd-desc{font-size:11px;color:var(--txt2);line-height:1.5;margin-bottom:10px}
.pcrd-btn{display:block;width:100%;padding:7px;border-radius:var(--r2);font-size:11px;font-weight:600;
  text-align:center;text-decoration:none;background:var(--pc,var(--cyan));color:var(--bg);transition:opacity .2s}
.pcrd-btn:hover{opacity:.85}
.pcrd-tip{margin-top:7px;padding:7px 9px;background:rgba(0,0,0,.3);border-radius:var(--r2);
  font-size:10px;color:var(--txt2);line-height:1.5;border-left:2px solid var(--pc,var(--cyan))}

/* TAGS */
.tag{display:inline-block;padding:2px 7px;border-radius:20px;font-size:9px;font-weight:600;letter-spacing:.3px}
.tg{background:rgba(0,212,255,.12);color:var(--cyan);border:1px solid rgba(0,212,255,.2)}
.tg-g{background:rgba(0,230,118,.12);color:var(--green);border:1px solid rgba(0,230,118,.2)}
.tg-y{background:rgba(255,215,64,.12);color:var(--yellow);border:1px solid rgba(255,215,64,.2)}
.tg-r{background:rgba(255,82,82,.12);color:var(--red);border:1px solid rgba(255,82,82,.2)}
.tg-p{background:rgba(192,132,252,.12);color:var(--purple);border:1px solid rgba(192,132,252,.2)}

/* FUNIL KANBAN */
.kanban{display:flex;gap:10px;overflow-x:auto;padding-bottom:8px}
.kanban::-webkit-scrollbar{height:4px}
.kanban::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}
.kcol{min-width:200px;background:var(--bg3);border-radius:var(--r);border:1px solid var(--border);overflow:hidden;flex-shrink:0}
.kcol-hdr{padding:9px 12px;font-family:'Syne',sans-serif;font-weight:700;font-size:11px;
  border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.kcol-body{padding:8px;display:flex;flex-direction:column;gap:6px;min-height:100px}
.kcard{background:var(--surf);border:1px solid var(--border);border-radius:var(--r2);padding:9px;cursor:default}
.kcard-title{font-size:12px;font-weight:600;margin-bottom:3px}
.kcard-sub{font-size:10px;color:var(--txt2)}

/* GLOSSARY */
.gloss{display:flex;gap:12px;padding:11px 0;border-bottom:1px solid var(--border)}
.gloss:last-child{border:none}
.gbadge{min-width:80px;padding:4px 7px;border-radius:var(--r2);font-size:9px;font-weight:700;
  text-align:center;align-self:flex-start;letter-spacing:.3px}
.gloss h4{font-size:12px;font-weight:600;margin-bottom:3px}
.gloss p{font-size:11px;color:var(--txt2);line-height:1.6}
.gloss .tip{margin-top:4px;font-size:10px;color:var(--green);font-style:italic}

/* DOC */
.doc-item{display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:var(--r2);
  border:1px solid var(--border);margin-bottom:6px;background:var(--surf);cursor:pointer;transition:all .18s}
.doc-item:hover{border-color:var(--border2)}
.doc-item.ok .dchk{background:var(--green);border-color:var(--green);color:var(--bg);font-weight:700}
.dchk{width:19px;height:19px;min-width:19px;border-radius:5px;border:2px solid var(--border2);
  display:flex;align-items:center;justify-content:center;font-size:10px;transition:all .18s}
.doc-name{font-size:12px;font-weight:500;flex:1}

/* PILL */
.pill{display:inline-block;padding:4px 11px;border-radius:20px;font-size:10px;font-weight:500;
  border:1px solid var(--border);color:var(--txt2);cursor:pointer;transition:all .15s;margin:2px}
.pill:hover{background:var(--cyan);color:var(--bg);border-color:var(--cyan)}

/* STEP */
.step{display:flex;gap:11px;padding:10px 0;border-bottom:1px solid var(--border)}
.step:last-child{border:none}
.step-n{width:26px;height:26px;min-width:26px;border-radius:50%;background:var(--cyan);color:var(--bg);
  display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;flex-shrink:0;margin-top:1px}
.step h4{font-size:12px;font-weight:600;margin-bottom:2px}
.step p{font-size:11px;color:var(--txt2);line-height:1.5}

/* TOAST */
#toast{position:fixed;bottom:16px;right:16px;background:var(--green);color:var(--bg);
  padding:8px 15px;border-radius:var(--r2);font-size:12px;font-weight:600;
  opacity:0;transform:translateY(8px);transition:all .3s;z-index:999;pointer-events:none}
#toast.show{opacity:1;transform:translateY(0)}

.mono{font-family:'JetBrains Mono',monospace}
.green{color:var(--green)}.red{color:var(--red)}.yellow{color:var(--yellow)}.cyan{color:var(--cyan)}
.muted{color:var(--txt2)}.bold{font-weight:700}.mb{margin-bottom:12px}
.divider{height:1px;background:var(--border);margin:12px 0}
</style>
</head>
<body>

<header>
  <div class="logo">🏛️ Licita<em>Track</em><span class="logo-tag">v1</span></div>
  <div class="hstats">
    <div class="hstat"><div class="hstat-v" id="hs-prog">0%</div><div class="hstat-l">Plano</div></div>
    <div class="hstat"><div class="hstat-v green" id="hs-funil">0</div><div class="hstat-l">Funil</div></div>
    <div class="hstat"><div class="hstat-v cyan" id="hs-docs">0</div><div class="hstat-l">Docs ok</div></div>
    <div class="hstat"><div class="hstat-v" id="hs-val">✅ ok</div><div class="hstat-l">Validades</div></div>
  </div>
</header>

<nav>
  <div class="tab active" onclick="goTab('plano')">⏱️ 15 Dias</div>
  <div class="tab" onclick="goTab('funil')">🎯 Funil</div>
  <div class="tab" onclick="goTab('prec')">💰 Preço</div>
  <div class="tab" onclick="goTab('disp')">⚡ Dispensa</div>
  <div class="tab" onclick="goTab('portais')">🌐 Portais</div>
  <div class="tab" onclick="goTab('validade')">📅 Validades</div>
  <div class="tab" onclick="goTab('gloss')">📖 Glossário</div>
</nav>

<main>

<!-- ══════ PLANO 15 DIAS ══════ -->
<div class="sec active" id="sec-plano">
  <div class="stitle">⏱️ Plano 15 Dias</div>
  <div class="ssub">Do zero à primeira venda. Marque cada tarefa conforme concluir.</div>

  <div class="card mb" style="padding:12px 16px">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px">
      <span style="font-size:12px;font-weight:600">Progresso geral</span>
      <span class="mono bold green" id="pct-txt">0%</span>
    </div>
    <div class="prog-wrap"><div class="prog-bar" id="bar-prog" style="width:0%"></div></div>
    <div style="display:flex;justify-content:space-between;margin-top:4px">
      <span class="muted" style="font-size:10px" id="pct-sub">0 de 0 tarefas</span>
      <button class="btn btn-ghost btn-sm" onclick="resetPlano()">↺ Reiniciar</button>
    </div>
  </div>

  <div id="plano-body"></div>
</div>

<!-- ══════ FUNIL ══════ -->
<div class="sec" id="sec-funil">
  <div class="stitle">🎯 Funil de Licitações</div>
  <div class="ssub">Acompanhe cada processo por fase. Use ◀ ▶ para mover entre fases.</div>

  <div class="card mb">
    <div style="font-size:12px;font-weight:600;color:var(--cyan);margin-bottom:10px">➕ Novo Processo</div>
    <div class="frow">
      <div class="fg" style="flex:2"><label>Produto / Objeto</label>
        <input id="fn-prod" placeholder="Ex: Kit theraband fisioterapia"></div>
      <div class="fg"><label>Órgão</label><input id="fn-orgao" placeholder="Ex: Pref. Santos"></div>
    </div>
    <div class="frow">
      <div class="fg"><label>Meu Preço (R$)</label><input id="fn-preco" type="number" placeholder="0,00"></div>
      <div class="fg"><label>Ref. Edital (R$)</label><input id="fn-ref" type="number" placeholder="0,00"></div>
      <div class="fg"><label>Fase</label>
        <select id="fn-fase">
          <option value="0">🔎 Oportunidade</option>
          <option value="1">📋 Qualificação</option>
          <option value="2">⚔️ Disputa</option>
          <option value="3">🏅 Classificação</option>
          <option value="4">📝 Contrato</option>
        </select></div>
    </div>
    <button class="btn btn-c" onclick="addProcesso()">➕ Adicionar</button>
  </div>

  <div class="kanban" id="kanban"></div>
</div>

<!-- ══════ PRECIFICAÇÃO ══════ -->
<div class="sec" id="sec-prec">
  <div class="stitle">💰 Precificação</div>
  <div class="ssub">Calcule o preço de venda com mark-up. Preencha os campos abaixo.</div>

  <div class="g2">
    <div>
      <div class="card">
        <div style="font-size:12px;font-weight:600;color:var(--cyan);margin-bottom:12px">📥 Dados</div>
        <div class="frow">
          <div class="fg"><label>Custo Unit. (R$)</label>
            <input id="p-custo" type="number" placeholder="0,00" step="0.01" oninput="calcP()"></div>
          <div class="fg"><label>Quantidade</label>
            <input id="p-qtd" type="number" value="1" oninput="calcP()"></div>
        </div>
        <div class="divider"></div>
        <div class="muted mb" style="font-size:10px;text-transform:uppercase;letter-spacing:.5px">Impostos (%)</div>
        <div class="frow">
          <div class="fg"><label>ICMS/Simples</label><input id="p-icms" type="number" value="0" step="0.1" oninput="calcP()"></div>
          <div class="fg"><label>PIS</label><input id="p-pis" type="number" value="0.65" step="0.01" oninput="calcP()"></div>
          <div class="fg"><label>COFINS</label><input id="p-cofins" type="number" value="3" step="0.01" oninput="calcP()"></div>
        </div>
        <div class="frow">
          <div class="fg"><label>Frete %</label><input id="p-frete" type="number" value="2" step="0.1" oninput="calcP()"></div>
          <div class="fg"><label>Outros %</label><input id="p-outros" type="number" value="1" step="0.1" oninput="calcP()"></div>
          <div class="fg"><label>Margem %</label><input id="p-margem" type="number" value="20" step="0.5" oninput="calcP()"></div>
        </div>
        <div class="fg" style="margin-bottom:0"><label>Preço Ref. Edital (R$)</label>
          <input id="p-ref" type="number" placeholder="0,00" step="0.01" oninput="calcP()"></div>
      </div>
    </div>

    <div class="card" style="background:var(--bg3)">
      <div style="font-size:12px;font-weight:600;color:var(--cyan);margin-bottom:12px">📊 Resultado</div>
      <div class="calc-row"><span class="calc-lbl">Custo unitário</span><span class="calc-val mono" id="r-c">R$ 0,00</span></div>
      <div class="calc-row"><span class="calc-lbl">Encargos + margem</span><span class="calc-val mono yellow" id="r-e">0%</span></div>
      <div class="calc-row"><span class="calc-lbl">Mark-up</span><span class="calc-val mono" id="r-mu">1,0000×</span></div>
      <div class="calc-row"><span class="calc-lbl">Lucro unitário</span><span class="calc-val mono" id="r-lu">R$ 0,00</span></div>
      <div class="calc-row"><span class="calc-lbl">Margem real</span><span class="calc-val mono" id="r-mr">0%</span></div>
      <div class="divider"></div>
      <div class="calc-row">
        <span class="calc-lbl bold" style="font-size:13px">⭐ Preço de Venda Unit.</span>
        <span class="calc-val calc-big mono" id="r-pv">R$ 0,00</span>
      </div>
      <div class="calc-row"><span class="calc-lbl">Preço Total (qtd)</span><span class="calc-val mono green" id="r-pt">R$ 0,00</span></div>
      <div class="calc-row"><span class="calc-lbl">Ref. do edital</span><span class="calc-val mono" id="r-ref">—</span></div>
      <div class="calc-row"><span class="calc-lbl">Competitivo?</span><span id="r-comp" class="bold">—</span></div>
      <div class="viab" id="r-viab">Preencha os dados</div>
    </div>
  </div>
</div>

<!-- ══════ DISPENSA ══════ -->
<div class="sec" id="sec-disp">
  <div class="stitle">⚡ Dispensa Eletrônica</div>
  <div class="ssub">Lei 14.133/2021 Art. 75 — tudo para participar.</div>

  <div class="g2">
    <div class="card" style="border-color:var(--cyan)">
      <div style="font-size:10px;color:var(--cyan);font-weight:700;letter-spacing:1px;margin-bottom:4px">BENS E SERVIÇOS</div>
      <div class="mono bold green" style="font-size:22px">R$ 57.828,31</div>
      <div class="muted" style="font-size:10px;margin-top:3px">Art. 75, II — corrigido pelo IPCA</div>
    </div>
    <div class="card" style="border-color:var(--purple)">
      <div style="font-size:10px;color:var(--purple);font-weight:700;letter-spacing:1px;margin-bottom:4px">OBRAS / ENGENHARIA</div>
      <div class="mono bold" style="font-size:22px;color:var(--purple)">R$ 115.656,63</div>
      <div class="muted" style="font-size:10px;margin-top:3px">Art. 75, I</div>
    </div>
  </div>

  <!-- VERIFICADOR -->
  <div class="card mb">
    <div style="font-size:12px;font-weight:600;color:var(--yellow);margin-bottom:10px">⚡ Verificar limite</div>
    <div class="frow">
      <div class="fg"><label>Valor da proposta (R$)</label>
        <input id="d-val" type="number" placeholder="0,00" oninput="checkLim()"></div>
      <div class="fg"><label>Modalidade</label>
        <select id="d-mod" onchange="checkLim()">
          <option value="57828.31">Bens e Serviços</option>
          <option value="115656.63">Obras e Engenharia</option>
        </select></div>
    </div>
    <div id="d-res" style="font-size:13px;font-weight:700;padding:10px;border-radius:var(--r2);display:none"></div>
  </div>

  <!-- DOCUMENTOS -->
  <div class="card mb">
