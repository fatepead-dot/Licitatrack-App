function diasRestantes(dataEmissao, prazo) {
  if (!dataEmissao || prazo >= 9999) return null;
  const emissao = new Date(dataEmissao + 'T12:00:00');
  const vence = new Date(emissao.getTime() + prazo * 86400000);
  const hoje = new Date();
  hoje.setHours(12,0,0,0);
  return Math.round((vence - hoje) / 86400000);
}

function statusValidade(dias, prazo) {
  if (prazo >= 9999) return {cls:'tg', label:'Sem prazo', cor:'var(--cyan)', bg:'rgba(0,212,255,.12)'};
  if (dias === null) return {cls:'tg-y', label:'⚠️ Não emitida', cor:'var(--yellow)', bg:'rgba(255,215,64,.12)'};
  if (dias < 0) return {cls:'tg-r', label:`❌ Vencida há ${Math.abs(dias)}d`, cor:'var(--red)', bg:'rgba(255,82,82,.15)'};
  if (dias <= 15) return {cls:'tg-r', label:`🚨 Vence em ${dias}d`, cor:'var(--red)', bg:'rgba(255,82,82,.15)'};
  if (dias <= 30) return {cls:'tg-y', label:`⚠️ Vence em ${dias}d`, cor:'var(--yellow)', bg:'rgba(255,215,64,.15)'};
  return {cls:'tg-g', label:`✅ ${dias} dias`, cor:'var(--green)', bg:'rgba(0,230,118,.12)'};
}

function addValidade() {
  const sel = document.getElementById('vl-doc').value.split('|');
  const doc = sel[0], prazo = parseInt(sel[1]);
  const data = document.getElementById('vl-data').value;
  const obs = document.getElementById('vl-obs').value;
  if (!data) { toast('⚠️ Informe a data de emissão!'); return; }

  // Update existing or add new
  const idx = validades.findIndex(v => v.doc === doc);
  if (idx >= 0) {
    validades[idx].data = data;
    validades[idx].obs = obs || validades[idx].obs;
    validades[idx].prazo = prazo;
  } else {
    validades.push({id: Date.now(), doc, prazo, data, obs});
  }
  S.set('validades', validades);
  document.getElementById('vl-data').value = '';
  document.getElementById('vl-obs').value = '';
  renderValidades();
  toast('✅ Certidão atualizada!');
  updateHeader();
}

function delValidade(id) {
  validades = validades.filter(v => v.id !== id);
  S.set('validades', validades);
  renderValidades();
  toast('🗑 Removido');
}

function renderValidades() {
  // Alertas urgentes
  const urgentes = validades.filter(v => {
    const d = diasRestantes(v.data, v.prazo);
    return d !== null && d <= 30;
  });

  const alertasEl = document.getElementById('val-alertas');
  if (urgentes.length) {
    alertasEl.innerHTML = `<div class="card mb" style="border-color:var(--red);background:rgba(255,82,82,.08)">
      <div style="font-size:12px;font-weight:700;color:var(--red);margin-bottom:10px">🚨 ATENÇÃO — ${urgentes.length} certidão(ões) precisam de ação!</div>
      ${urgentes.map(v => {
        const d = diasRestantes(v.data, v.prazo);
        return `<div style="display:flex;justify-content:space-between;align-items:center;padding:6px 0;border-bottom:1px solid rgba(255,82,82,.2)">
          <span style="font-size:12px;font-weight:600">${v.doc}</span>
          <span class="tag tg-r">${d < 0 ? `❌ Vencida há ${Math.abs(d)}d` : `🚨 Vence em ${d}d`}</span>
        </div>`;
      }).join('')}
    </div>`;
  } else {
    alertasEl.innerHTML = '';
  }

  // Lista completa
  // Sort: vencidas primeiro, depois por dias restantes
  const sorted = [...validades].sort((a, b) => {
    const da = diasRestantes(a.data, a.prazo) ?? 9998;
    const db = diasRestantes(b.data, b.prazo) ?? 9998;
    return da - db;
  });

  document.getElementById('val-lista').innerHTML = sorted.map(v => {
    const dias = diasRestantes(v.data, v.prazo);
    const st = statusValidade(dias, v.prazo);
    const dataFmt = v.data ? new Date(v.data + 'T12:00:00').toLocaleDateString('pt-BR') : '—';
    const venceFmt = () => {
      if (!v.data || v.prazo >= 9999) return '—';
      const d = new Date(v.data + 'T12:00:00');
      d.setDate(d.getDate() + v.prazo);
      return d.toLocaleDateString('pt-BR');
    };

    // Progress bar
    let progPct = 0, progCor = 'var(--green)';
    if (v.data && v.prazo < 9999) {
      progPct = Math.max(0, Math.min(100, Math.round(((v.prazo - (dias||0)) / v.prazo) * 100)));
      progCor = dias < 0 ? 'var(--red)' : dias <= 15 ? 'var(--red)' : dias <= 30 ? 'var(--yellow)' : 'var(--green)';
    }

    return `<div class="card mb" style="border-color:${st.bg.replace('.12','.3').replace('.15','.3')}">
      <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:10px;margin-bottom:8px">
        <div style="flex:1">
          <div style="font-size:13px;font-weight:600">${v.doc}</div>
          ${v.obs ? `<div class="muted" style="font-size:10px;margin-top:2px">${v.obs}</div>` : ''}
        </div>
        <span class="tag" style="background:${st.bg};color:${st.cor};border:1px solid ${st.cor}40;white-space:nowrap">${st.label}</span>
      </div>
      <div style="display:flex;gap:16px;font-size:11px;color:var(--txt2);margin-bottom:8px;flex-wrap:wrap">
        <span>📅 Emitida: <strong style="color:var(--txt)">${dataFmt}</strong></span>
        <span>⏳ Prazo: <strong style="color:var(--txt)">${v.prazo >= 9999 ? 'Sem prazo' : v.prazo+' dias'}</strong></span>
        <span>📆 Vence: <strong style="color:${st.cor}">${venceFmt()}</strong></span>
      </div>
      ${v.data && v.prazo < 9999 ? `
      <div class="prog-wrap" style="height:5px;margin-bottom:10px">
        <div class="prog-bar" style="width:${progPct}%;background:${progCor}"></div>
      </div>` : ''}
      <div style="display:flex;gap:6px;flex-wrap:wrap">
        <button class="btn btn-c btn-sm" onclick="renovarDoc(${v.id})">🔄 Atualizar data</button>
        <button class="btn btn-ghost btn-sm" onclick="delValidade(${v.id})">🗑</button>
      </div>
    </div>`;
  }).join('');

  updateHeader();
}

function renovarDoc(id) {
  const v = validades.find(x => x.id === id);
  if (!v) return;
  const hoje = new Date().toISOString().split('T')[0];
  const data = prompt(`Nova data de emissão para:\n"${v.doc}"`, hoje);
  if (!data) return;
  v.data = data;
  S.set('validades', validades);
  renderValidades();
  toast('✅ Data atualizada!');
}

