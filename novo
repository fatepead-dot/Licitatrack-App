  const done=Object.values(planoState).filter(Boolean).length;
  document.getElementById('hs-prog').textContent=(total?Math.round(done/total*100):0)+'%';
  document.getElementById('hs-funil').textContent=processos.length;
  const docsDone=Object.values(docsState).filter(Boolean).length;
  document.getElementById('hs-docs').textContent=docsDone+'/'+DOCS.length;
  // Validades urgentes no header
  const vurg = validades.filter(v => { const d=diasRestantes(v.data,v.prazo); return d!==null&&d<=30; }).length;
  const hv = document.getElementById('hs-val');
  if(hv) { hv.textContent = vurg > 0 ? '⚠️ '+vurg : '✅ ok'; hv.style.color = vurg > 0 ? 'var(--red)' : 'var(--green)'; }
}

