function calcP(){
  const c=parseFloat(document.getElementById('p-custo').value)||0;
  const q=parseFloat(document.getElementById('p-qtd').value)||1;
  const icms=(parseFloat(document.getElementById('p-icms').value)||0)/100;
  const pis=(parseFloat(document.getElementById('p-pis').value)||0)/100;
  const cof=(parseFloat(document.getElementById('p-cofins').value)||0)/100;
  const fre=(parseFloat(document.getElementById('p-frete').value)||0)/100;
  const out=(parseFloat(document.getElementById('p-outros').value)||0)/100;
  const mar=(parseFloat(document.getElementById('p-margem').value)||0)/100;
  const ref=parseFloat(document.getElementById('p-ref').value)||0;
  const enc=icms+pis+cof+fre+out+mar;
  const mu=enc<1?1/(1-enc):0;
  const pv=c*mu,pt=pv*q,lu=pv-c,mr=pv>0?lu/pv:0;
  document.getElementById('r-c').textContent=fmt(c);
  document.getElementById('r-e').textContent=fmtP(enc-mar)+' enc + '+fmtP(mar)+' margem';
  document.getElementById('r-mu').textContent=enc<1?mu.toFixed(4)+'×':'ERRO';
  document.getElementById('r-lu').textContent=fmt(lu);
  document.getElementById('r-mr').textContent=fmtP(mr);
  document.getElementById('r-pv').textContent=enc<1?fmt(pv):'ERRO';
  document.getElementById('r-pt').textContent=fmt(pt);
  if(ref>0){
    document.getElementById('r-ref').textContent=fmt(ref);
    document.getElementById('r-comp').innerHTML=pv<=ref
      ?`<span class="green">✅ Sim — ${fmt(ref-pv)} abaixo</span>`
      :`<span class="red">❌ Não — ${fmt(pv-ref)} acima</span>`;
  }else{document.getElementById('r-ref').textContent='—';document.getElementById('r-comp').textContent='Informe a referência';}
  const v=document.getElementById('r-viab');
  if(enc>=1){v.textContent='⚠️ Soma ≥ 100%';v.style.cssText='background:rgba(255,82,82,.15);color:var(--red)';return;}
  if(!c){v.textContent='Preencha os dados';v.style.cssText='background:var(--surf);color:var(--txt2)';return;}
  if(mr<.05){v.textContent='⚠️ Margem muito baixa';v.style.cssText='background:rgba(255,82,82,.15);color:var(--red)';}
  else if(mr<.10){v.textContent='🟡 Margem baixa — cuidado';v.style.cssText='background:rgba(255,215,64,.15);color:var(--yellow)';}
  else if(ref>0&&pv>ref){v.textContent='❌ Acima da referência';v.style.cssText='background:rgba(255,82,82,.15);color:var(--red)';}
  else{v.textContent='✅ Viável — bom para participar!';v.style.cssText='background:rgba(0,230,118,.12);color:var(--green)';}
}

